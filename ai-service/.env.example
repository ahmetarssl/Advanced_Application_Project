# LLM - en az birini doldur
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Kullanilacak model (openai: gpt-4o-mini | anthropic: claude-haiku-4-5-20251001)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# PostgreSQL - MUTLAKA ai_readonly kullanicisi kullan!
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapulse
DB_USER=ai_readonly
DB_PASSWORD=your_readonly_password_here

# Servis
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Guvenlik limitleri
MAX_QUESTION_LENGTH=500
MAX_QUERY_LIMIT=1000
QUERY_TIMEOUT_SECONDS=5
